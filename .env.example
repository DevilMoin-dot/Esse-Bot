# ─────────────────────────────────────────────────────────────────────────────
# Discord Bot — Environment Variables
#
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Your Discord bot token.
# Found at: https://discord.com/developers/applications → Your App → Bot → Token
TOKEN=your_discord_bot_token_here

# Your Discord application (client) ID.
# Found at: https://discord.com/developers/applications → Your App → General Information → Application ID
CLIENT_ID=your_discord_application_id_here

# Your YouTube Data API v3 key.
# Create one at: https://console.cloud.google.com → APIs & Services → Credentials
# Make sure the YouTube Data API v3 is enabled in your project.
YOUTUBE_API_KEY=your_youtube_api_key_here

# HTTP port for the Express keep-alive server.
# On Replit this is set automatically; leave it as-is.
PORT=3000

